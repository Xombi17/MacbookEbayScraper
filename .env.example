# ─────────────────────────────────────────
#  MacBook Deal Intelligence System
#  Environment Variable Template
#  Copy to .env and fill in your values
# ─────────────────────────────────────────

# ── Scraping ──────────────────────────────
FIRECRAWL_API_KEY=fc-your-key-here

# ── AI Filtering (GitHub Models) ─────────────
# Get a token at https://github.com/settings/tokens (no extra scopes needed)
GITHUB_TOKEN=github_pat_your_token_here
# Full list of models: https://github.com/marketplace/models
GITHUB_CHAT_MODEL=openai/gpt-4o

# ── Telegram Notifications ────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# ── Database ──────────────────────────────
# MongoDB URI (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/macbook_deals

# ── Pipeline Settings ─────────────────────
# Minimum score (0-10) to trigger Telegram alert
DEAL_SCORE_THRESHOLD=7.0

# Maximum acceptable price in USD
MAX_PRICE_USD=1500.0

# Pipeline run interval in hours
RUN_INTERVAL_HOURS=6

# ── Feature Flags ─────────────────────────
# Set to "false" to disable AI filtering (saves API credits)
ENABLE_AI_FILTER=true

# Set to "false" to disable Telegram notifications
ENABLE_TELEGRAM=true
